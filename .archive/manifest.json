{
  "manifest_version": 3,
  "name": "AlgoMind Fair Play",
  "version": "1.0.0",
  "description": "Enforces fair play during AlgoMind Friends Code Party challenges on LeetCode & Codeforces.",
  "permissions": [
    "tabs",
    "windows",
    "storage",
    "alarms",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "*://leetcode.com/*",
    "*://codeforces.com/*",
    "*://localhost/*",
    "*://*.algomind.app/*",
    "*://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost/*",
        "*://*.algomind.app/*",
        "*://*.onrender.com/*"
      ],
      "js": ["content/algomind.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://leetcode.com/*",
        "*://codeforces.com/*"
      ],
      "js": ["content/platforms.js"],
      "css": ["content/platform-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/platform-overlay.css"],
      "matches": ["*://leetcode.com/*", "*://codeforces.com/*"]
    }
  ]
}
